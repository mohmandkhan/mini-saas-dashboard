# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust the values for your environment.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma.
# The default matches the docker-compose Postgres service in this repo.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mini_saas?schema=public"

# Secret used to sign JWT auth tokens. Use a long random string in production.
# Generate one with:  openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret-string"

# How long an auth session stays valid (seconds). Default: 7 days.
JWT_EXPIRES_IN_SECONDS="604800"

# Credentials created by the seed script for the first demo login.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="admin123"
